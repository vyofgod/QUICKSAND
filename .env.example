# SurrealDB Database
SURREALDB_URL="ws://localhost:8000/rpc"
SURREALDB_NAMESPACE="devfocus"
SURREALDB_DATABASE="main"
SURREALDB_USER="root"
SURREALDB_PASSWORD="root"

# NextAuth v5
AUTH_SECRET="your-auth-secret-here" # Generate with: openssl rand -base64 32
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"
AUTH_GITLAB_ID="your-gitlab-oauth-app-id"
AUTH_GITLAB_SECRET="your-gitlab-oauth-app-secret"

# Note: GitHub OAuth App needs these scopes: read:user, user:email, repo
# Note: GitLab OAuth App needs these scopes: read_user, read_api, read_repository

# Application URLs
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.1-flash-lite-preview"

# GitHub API (for activity metrics)
GITHUB_PERSONAL_ACCESS_TOKEN="your-github-pat"

# GitLab API (for activity metrics)
GITLAB_PERSONAL_ACCESS_TOKEN="your-gitlab-pat"
GITLAB_API_URL="https://gitlab.com/api/v4"

# Feature Flags
NEXT_PUBLIC_ENABLE_OFFLINE_MODE="true"
NEXT_PUBLIC_ENABLE_AI_INSIGHTS="true"

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=""

# Environment
NODE_ENV="development"
